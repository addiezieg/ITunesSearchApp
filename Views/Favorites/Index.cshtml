@model List<ITunesSearchApp.Models.FavoriteAlbum>

@{
    ViewData["Title"] = "Addie's Favorites";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Addie's Favorites</h1>
        <p class="text-muted fs-5">A curated collection of albums I love.</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var album in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        @if (!string.IsNullOrWhiteSpace(album.ArtworkUrl100))
                        {
                            <img src="@album.ArtworkUrl100.Replace("100x100", "300x300")"
                                 class="card-img-top"
                                 alt="@album.CollectionName"
                                 style="height: 260px; object-fit: cover;" />
                        }

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-semibold">@album.CollectionName</h5>

                            <p class="card-text text-muted mb-2">
                                <strong>Artist:</strong> @album.ArtistName
                            </p>

                            @if (!string.IsNullOrWhiteSpace(album.Note))
                            {
                                <p class="card-text text-muted mb-3">@album.Note</p>
                            }

                            <a asp-controller="Favorites"
                               asp-action="Details"
                               asp-route-id="@album.Id"
                               class="btn btn-outline-dark mt-auto rounded-pill">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center mt-5">
            <p class="fs-5 text-muted">No favorites added yet.</p>
        </div>
    }
</div>