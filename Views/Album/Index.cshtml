@model List<ITunesSearchApp.Models.Album>

@{
    ViewData["Title"] = "Album Search";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">iTunes Album Search</h1>
        <p class="text-muted fs-5">Search for your favorite artists and browse their albums.</p>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-8 col-lg-6">
            <form method="get" asp-action="Index" asp-controller="Album">
                <div class="input-group input-group-lg shadow-sm">
                    <input
                        type="text"
                        name="term"
                        class="form-control"
                        placeholder="Search for albums or artists..."
                        value="@ViewData["CurrentSearchTerm"]" />
                    <button class="btn btn-dark" type="submit">Search</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var album in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        <img src="@album.ArtworkUrl100.Replace("100x100", "300x300")"
                             class="card-img-top"
                             alt="@album.CollectionName"
                             style="height: 260px; object-fit: cover;" />

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-semibold">@album.CollectionName</h5>
                            <p class="card-text text-muted mb-1">
                                <strong>Artist:</strong> @album.ArtistName
                            </p>
                            <p class="card-text text-muted mb-3">
                                <strong>Released:</strong> @album.ReleaseDate.ToShortDateString()
                            </p>

                            <a href="/Album/Details/@album.CollectionId" class="btn btn-outline-dark mt-auto rounded-pill">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center mt-5">
            <p class="fs-5 text-muted">No albums found. Try searching for another artist.</p>
        </div>
    }
</div>