@model ITunesSearchApp.Models.AlbumDetailViewModel

<a href="/">Back to Search</a>

@if (Model?.Album != null)
{
    <h1>@Model.Album.CollectionName</h1>
    <p>Artist: @Model.Album.ArtistName</p>
    <p>Release Date: @Model.Album.ReleaseDate.ToShortDateString()</p>
    <p>Genre: @Model.Album.PrimaryGenreName</p>

    @if (!string.IsNullOrWhiteSpace(Model.Album.ArtworkUrl100))
    {
        <img src="@Model.Album.ArtworkUrl100.Replace("100x100", "300x300")" alt="Album Artwork" />
    }

    <h2>Track List</h2>

    @if (Model.Songs != null && Model.Songs.Any())
    {
        <ul>
            @foreach (var song in Model.Songs)
            {
                <li>@song.TrackNumber. @song.TrackName</li>
            }
        </ul>
    }
    else
    {
        <p>No tracks found for this album.</p>
    }
}
else
{
    <p>@Model?.ErrorMessage</p>
}