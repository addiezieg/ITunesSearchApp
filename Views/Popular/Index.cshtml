@model List<ITunesSearchApp.Models.Album>

@{
    ViewData["Title"] = "Today's Most Popular Albums";
    int rank = 1;
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Today's Top Albums</h1>
        <p class="text-muted fs-5">Browse the current most popular albums on ITunes.</p>
    </div>

    <div class="d-flex justify-content-center gap-3 mb-5">
        <a asp-controller="Album" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">
            Search Albums
        </a>
        <a asp-controller="Popular" asp-action="Index" class="btn btn-dark rounded-pill px-4">
           Top Albums
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var album in Model)
            {
                var badgeClass = rank == 1
                    ? "bg-warning text-dark"
                    : rank == 2
                        ? "bg-secondary text-white"
                        : rank == 3
                            ? "bg-danger text-white"
                            : "bg-dark text-white";

                var borderClass = rank == 1
                    ? "border border-warning border-3"
                    : rank == 2
                        ? "border border-secondary border-3"
                        : rank == 3
                            ? "border border-danger border-3"
                            : "";

                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden position-relative @borderClass">
                        <span class="position-absolute top-0 start-0 m-2 badge @badgeClass fs-6 px-3 py-2">
                            #@rank
                        </span>

                        <img src="@album.ArtworkUrl100.Replace("100x100", "300x300")"
                             class="card-img-top"
                             alt="@album.CollectionName"
                             style="height: 260px; object-fit: cover;" />

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-semibold">@album.CollectionName</h5>

                            <p class="card-text text-muted mb-1">
                                <strong>Artist:</strong> @album.ArtistName
                            </p>

                            <p class="card-text text-muted mb-3">
                                <strong>Released:</strong>
                                @(album.ReleaseDate == DateTime.MinValue
                                    ? "Unknown"
                                    : album.ReleaseDate.ToShortDateString())
                            </p>

                            @if (album.CollectionId > 0)
                            {
                                <a asp-controller="Album"
                                   asp-action="Details"
                                   asp-route-id="@album.CollectionId"
                                   asp-route-source="popular"
                                   class="btn btn-outline-dark mt-auto rounded-pill">
                                    View Details
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary mt-auto rounded-pill" disabled>
                                    Details Unavailable
                                </button>
                            }
                        </div>
                    </div>
                </div>

                rank++;
            }
        </div>
    }
    else
    {
        <div class="text-center mt-5">
            <p class="fs-5 text-muted">No popular albums are available right now.</p>
        </div>
    }
</div>